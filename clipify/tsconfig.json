{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "nodenext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "noEmit": true,
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}
